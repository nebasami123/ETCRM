{
  "name": "etcrm-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "prisma migrate deploy && tsx src/server.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:prod": "tsx prisma/seed-production.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "db:reset": "prisma migrate reset --force",
    "prisma": "prisma"
  },
  "dependencies": {
    "@etcrm/contracts": "workspace:*",
    "@json2csv/plainjs": "^7.0.6",
    "@prisma/client": "^6.10.1",
    "better-auth": "1.6.23",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "multer": "^2.0.1",
    "tsx": "^4.22.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "nodemon": "^3.1.10",
    "prisma": "^6.10.1",
    "typescript": "^5.9.3"
  }
}
