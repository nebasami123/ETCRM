generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum LeadPhase {
  NEW
  CONTACTED
  FOLLOW_UP
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  LEAD_CREATED
  LEAD_IMPORTED
  LEAD_CLAIMED
  CLAIM_TRANSFER_REQUESTED
  CLAIM_TRANSFER_APPROVED
  CLAIM_TRANSFER_REJECTED
  CALL_NOTE
  PHASE_CHANGED
  APPOINTMENT_SET
  FOLLOW_UP_SET
}

enum ClaimRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("SALES")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime? @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  accounts              Account[]
  sessions              Session[]
  createdLeads          Lead[]                 @relation("CreatedLeads")
  claimedLeads          Lead[]                 @relation("ClaimedLeads")
  events                ActivityEvent[]        @relation("EventActor")
  conversionCredits     ActivityEvent[]        @relation("ConversionCredit")
  quotas                Quota[]
  claimRequests         ClaimTransferRequest[] @relation("RequestedClaimTransfers")
  resolvedClaimRequests ClaimTransferRequest[] @relation("ResolvedClaimTransfers")
}

model Session {
  id             String    @id
  expiresAt      DateTime  @db.Timestamptz(3)
  token          String    @unique
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(3)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  @@index([identifier])
}

model Lead {
  id                    String    @id @default(cuid())
  fullName              String
  phoneNumber           String
  phoneKey              String    @unique
  email                 String    @default("")
  phase                 LeadPhase @default(NEW)
  createdById           String?
  createdBy             User?     @relation("CreatedLeads", fields: [createdById], references: [id], onDelete: SetNull)
  claimedById           String?
  claimedBy             User?     @relation("ClaimedLeads", fields: [claimedById], references: [id], onDelete: SetNull)
  claimedAt             DateTime? @db.Timestamptz(3)
  appointmentDate       DateTime? @db.Timestamptz(3)
  nextFollowUpAt        DateTime? @db.Timestamptz(3)
  dateRegistered        DateTime? @db.Timestamptz(3)
  legalStatusNameEng    String?
  legalStatusNameAmh    String?
  status                String?
  licenceNumber         String?
  licenceKey            String?   @unique
  renewedTo             DateTime? @db.Timestamptz(3)
  siteId                String?
  businessName          String?
  businessNameAmharic   String?
  managerFName          String?
  managerMName          String?
  managerLName          String?
  description           String?
  code                  String?
  englishDescription    String?
  amDescription         String?
  subGroup              String?
  subGroupAm            String?
  subGroupEn            String?
  businessRegion        String?
  businessZone          String?
  businessWoreda        String?
  businessKebele        String?
  houseNumber           String?
  businessTelephone     String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(3)

  events                ActivityEvent[]
  claimTransferRequests ClaimTransferRequest[]

  @@index([phase])
  @@index([claimedById])
  @@index([createdById])
  @@index([nextFollowUpAt])
  @@index([appointmentDate])
}

model ActivityEvent {
  id             String       @id @default(cuid())
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actorId        String
  actor          User         @relation("EventActor", fields: [actorId], references: [id])
  creditedUserId String?
  creditedUser   User?        @relation("ConversionCredit", fields: [creditedUserId], references: [id], onDelete: SetNull)
  type           ActivityType
  note           String?
  fromPhase      LeadPhase?
  toPhase        LeadPhase?
  metadata       Json?
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)

  @@index([leadId, createdAt])
  @@index([actorId, createdAt])
  @@index([creditedUserId, createdAt])
  @@index([type, createdAt])
}

model ClaimTransferRequest {
  id           String             @id @default(cuid())
  leadId       String
  lead         Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy  User               @relation("RequestedClaimTransfers", fields: [requestedById], references: [id])
  status       ClaimRequestStatus @default(PENDING)
  reason       String
  resolvedById String?
  resolvedBy   User?              @relation("ResolvedClaimTransfers", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?          @db.Timestamptz(3)
  createdAt    DateTime           @default(now()) @db.Timestamptz(3)

  @@index([leadId, status])
  @@index([requestedById, status])
}

model Quota {
  id          String   @id @default(cuid())
  salesUserId String
  salesUser   User     @relation(fields: [salesUserId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  callsTarget Int      @default(0)
  leadsTarget Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@unique([salesUserId, date])
  @@index([date])
}
